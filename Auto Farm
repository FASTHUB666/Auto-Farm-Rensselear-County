    -- ========== MONEY TRACKER ==========
    local function setupMoneyTracker()
        local leaderstats = player:FindFirstChild("leaderstats")
        if not leaderstats then
            local stats = player:WaitForChild("leaderstats", 5)
            if stats then leaderstats = stats end
        end
        
        if leaderstats then
            moneyValue = leaderstats:FindFirstChild("Money") or leaderstats:FindFirstChild("Cash")
            if moneyValue then
                moneyValue.Changed:Connect(function(newVal)
                    if farming and newVal > currentMoney then
                        local diff = newVal - currentMoney
                        moneyGained = moneyGained + diff
                        MoneyGained.Text = "+$" .. formatNumber(moneyGained)
                        currentMoney = newVal
                        MoneyLabel.Text = "$" .. formatNumber(currentMoney)
                    end
                end)
                return moneyValue.Value
            end
        end
        return 0
    end

